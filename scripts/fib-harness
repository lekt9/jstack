#!/usr/bin/env bash
set -euo pipefail

# fib-harness — Fractal Fibonacci-scaled subagent verification
# FRACTAL: judge spawns child harnesses when not passing. Max depth: 3.
# Harness collects artifacts, agent judges between sub-commands.

FIB=(1 1 2 3 5 8)
MAX_DEPTH=3

now_iso() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }

py() { python3 -c "$1"; }

case "${1:-help}" in

# ── init ──────────────────────────────────────────────────────────
init)
  proj="${2:?usage: fib-harness init <project-path>}"
  proj="$(cd "$proj" && pwd)"
  ws="/tmp/fib-$(basename "$proj")-$(date +%s)"
  mkdir -p "$ws"/{artifacts/{L1,L2,L3,L4,L5,L6},state,children}

  py "
import json, os, subprocess

proj = '$proj'
ws = '$ws'

# scan
exts = {}
for root, dirs, files in os.walk(proj):
    dirs[:] = [d for d in dirs if d not in ('node_modules','.git','dist','build','__pycache__','.next')]
    for f in files:
        ext = os.path.splitext(f)[1]
        if ext: exts[ext] = exts.get(ext, 0) + 1

key_files = [f for f in ('package.json','tsconfig.json','Cargo.toml','pyproject.toml','go.mod',
    'Makefile','Dockerfile','docker-compose.yml','README.md','CLAUDE.md') if os.path.exists(os.path.join(proj, f))]

dirs_found = [d for d in ('src','lib','app','test','tests','spec','docs','scripts','bin','config','public')
    if os.path.isdir(os.path.join(proj, d))]

git_info = None
if os.path.isdir(os.path.join(proj, '.git')):
    try:
        branch = subprocess.check_output(['git','-C',proj,'branch','--show-current'], text=True, stderr=subprocess.DEVNULL).strip()
        commits = subprocess.check_output(['git','-C',proj,'rev-list','--count','HEAD'], text=True, stderr=subprocess.DEVNULL).strip()
        git_info = {'branch': branch, 'commits': int(commits)}
    except: pass

scan = {'project_path': proj, 'scan_time': '$(now_iso)', 'file_counts': exts, 'key_files': key_files,
    'directories': dirs_found, 'git': git_info, 'workspace': ws}

state = {'workspace': ws, 'project_path': proj, 'created': '$(now_iso)', 'depth': 1, 'max_depth': $MAX_DEPTH,
    'parent_workspace': None, 'scope': 'root', 'current_level': 0, 'current_cycle': 1,
    'dimensions_registered': False, 'levels_complete': [], 'children': [], 'status': 'initialized'}

with open(f'{ws}/state/project-scan.json','w') as f: json.dump(scan, f, indent=2)
with open(f'{ws}/state/harness.json','w') as f: json.dump(state, f, indent=2)
print(json.dumps(scan, indent=2))
"
  ;;

# ── dimensions ────────────────────────────────────────────────────
# Register the 6 Genesis-day dimensions for this workspace.
# Domain-general: each dimension declares primitive_type (code|skill|hybrid)
# and the concrete primitive that executes it.
dimensions)
  ws="${2:?usage: fib-harness dimensions <workspace> <dims-json-or-path>}"
  dims="${3:?provide dimensions JSON string or @/path/to/file}"
  py "
import json, os, sys
raw = '''$dims'''
if raw.startswith('@') and os.path.isfile(raw[1:]):
    d = json.load(open(raw[1:]))
elif os.path.isfile(raw):
    d = json.load(open(raw))
elif raw.lstrip().startswith('{') or raw.lstrip().startswith('['):
    d = json.loads(raw)
else:
    sys.exit('ERROR: pass a JSON string or a file path (optionally @prefixed)')

if 'dimensions' not in d or len(d['dimensions']) != 6:
    sys.exit('ERROR: exactly 6 dimensions required')
domain = d.get('domain', 'unspecified')
problem = d.get('problem', '')

always = ['name','genesis_day','question','primitive_type','primitive_name','success_criteria']
allowed = ('code','skill','hybrid')
for i, dim in enumerate(d['dimensions']):
    miss = [f for f in always if f not in dim or not dim[f]]
    if miss: sys.exit(f'ERROR: dim[{i}] missing {miss}')
    pt = dim['primitive_type']
    if pt not in allowed:
        sys.exit(f'ERROR: dim[{i}] primitive_type must be one of {allowed}')
    if pt == 'code' and not (dim.get('commands') or dim.get('files')):
        sys.exit(f'ERROR: dim[{i}] primitive_type=code requires commands or files')
    if pt == 'skill' and not dim.get('skill_invocation'):
        sys.exit(f'ERROR: dim[{i}] primitive_type=skill requires skill_invocation')
    if pt == 'hybrid' and not (dim.get('commands') and dim.get('skill_invocation')):
        sys.exit(f'ERROR: dim[{i}] primitive_type=hybrid requires both commands and skill_invocation')

with open('$ws/state/dimensions.json','w') as f: json.dump(d, f, indent=2)
with open('$ws/state/harness.json') as f: s = json.load(f)
s['dimensions_registered'] = True
s['status'] = 'dimensions_set'
s['domain'] = domain
s['problem'] = problem
with open('$ws/state/harness.json','w') as f: json.dump(s, f, indent=2)
print(json.dumps({'ok':True,'domain':domain,'dimensions':6,
    'primitives':[{'L':i+1,'day':x['genesis_day'],'name':x['name'],
        'type':x['primitive_type'],'primitive':x['primitive_name']}
        for i,x in enumerate(d['dimensions'])]}, indent=2))
"
  ;;

# ── plan ──────────────────────────────────────────────────────────
# Print the primitive plan: which agents at which level run which primitive.
plan)
  ws="${2:?usage: fib-harness plan <ws>}"
  py "
import json, os
with open('$ws/state/harness.json') as f: s = json.load(f)
dp = '$ws/state/dimensions.json'
if not os.path.exists(dp):
    print(json.dumps({'error':'no dimensions — run: fib-harness dimensions <ws> <json>'}))
    raise SystemExit(1)
with open(dp) as f: d = json.load(f)
fib = [1,1,2,3,5,8]
days = ['light','firmament','land','luminaries','creatures','dominion']
plan = {'workspace':'$ws','domain':s.get('domain','unspecified'),
    'problem':s.get('problem',''),'total_agents':sum(fib),'levels':[]}
for i, dim in enumerate(d['dimensions']):
    plan['levels'].append({'level':i+1,'genesis_day':days[i],'agents':fib[i],
        'dimension':dim['name'],'question':dim['question'],
        'primitive_type':dim['primitive_type'],'primitive_name':dim['primitive_name'],
        'commands':dim.get('commands'),'skill_invocation':dim.get('skill_invocation'),
        'files':dim.get('files'),'success_criteria':dim['success_criteria'],
        'failure_indicators':dim.get('failure_indicators')})
print(json.dumps(plan, indent=2))
"
  ;;

# ── domains ───────────────────────────────────────────────────────
# Print known domain templates (full templates live in SKILL.md).
domains)
  cat <<'DOMAINS'
Known domains (see SKILL.md for 6-day templates per domain):
  code          shell / typecheck / runtime assertions
  content       copy, drafts, engagement metrics
  sales         pipeline, outreach, replies, close
  fundraising   investor list, deck, SAFE, commits
  research      sources, synthesis, hypothesis tests
  operations    metrics, rituals, orgs, loops
  product       PRD, roadmap, user research
  ml            data, checkpoints, eval, deploy
  growth        funnel, activation, retention
  pastoral      facts, scripture, body, next-step (daylight only)

Declare a new domain in your dimensions JSON:
  { "domain": "<name>", "problem": "<one-liner>",
    "dimensions": [ 6 objects with: name, genesis_day, question,
      primitive_type (code|skill|hybrid), primitive_name,
      success_criteria, plus commands/files for code or
      skill_invocation for skill, or both for hybrid ] }
DOMAINS
  ;;

# ── collect ───────────────────────────────────────────────────────
collect)
  ws="${2:?usage: fib-harness collect <ws> <level> <agent-id> <artifact-json>}"
  level="${3:?level 1-6}"
  agent="${4:?agent id}"
  artifact="${5:?artifact JSON or @filepath}"
  py "
import json, sys, os

level = int('$level')
if level < 1 or level > 6: sys.exit('ERROR: level must be 1-6')

art_input = '''$artifact'''
if art_input.startswith('@'):
    with open(art_input[1:]) as f: a = json.load(f)
else:
    a = json.loads(art_input)

for field in ('level','agent_id','dimension','hypotheses','summary'):
    if field not in a: sys.exit(f'ERROR: missing {field}')
if not isinstance(a['hypotheses'], list) or len(a['hypotheses']) == 0:
    sys.exit('ERROR: hypotheses must be non-empty list')
for i, h in enumerate(a['hypotheses']):
    for hf in ('id','claim','evidence','status'):
        if hf not in h: sys.exit(f'ERROR: hypothesis[{i}] missing {hf}')
    if h['status'] not in ('pass','fail','unknown'):
        sys.exit(f\"ERROR: hypothesis[{i}] status must be pass|fail|unknown\")

with open('$ws/state/harness.json') as f: state = json.load(f)
cycle = state.get('current_cycle', 1)
d = f'$ws/repair/cycle{cycle}/L{level}' if cycle > 1 else f'$ws/artifacts/L{level}'
os.makedirs(d, exist_ok=True)
with open(f'{d}/$agent.json','w') as f: json.dump(a, f, indent=2)
print(f'OK: L{level}/$agent collected (cycle {cycle})')
"
  ;;

# ── level-check ───────────────────────────────────────────────────
level-check)
  ws="${2:?usage: fib-harness level-check <ws> <level>}"
  level="${3:?level 1-6}"
  py "
import json, os, glob

level = int('$level')
fib = [1,1,2,3,5,8]
days = ['light','firmament','land','luminaries','creatures','dominion']
expected = fib[level-1]
day = days[level-1]

with open('$ws/state/harness.json') as f: state = json.load(f)
cycle = state.get('current_cycle', 1)
d = f'$ws/repair/cycle{cycle}/L{level}' if cycle > 1 else f'$ws/artifacts/L{level}'

actual = len(glob.glob(f'{d}/*.json')) if os.path.isdir(d) else 0
if actual != expected:
    print(json.dumps({'level':level,'genesis_day':day,'expected':expected,'actual':actual,'status':'INCOMPLETE'},indent=2))
    import sys; sys.exit(1)

total=passed=failed=unknown=0
for fp in sorted(glob.glob(f'{d}/*.json')):
    with open(fp) as f: art = json.load(f)
    for h in art.get('hypotheses',[]):
        total += 1
        if h['status']=='pass': passed+=1
        elif h['status']=='fail': failed+=1
        else: unknown+=1

if level not in state['levels_complete']: state['levels_complete'].append(level)
state['levels_complete'].sort()
state['current_level'] = level
state['status'] = f'level_{level}_complete'
with open('$ws/state/harness.json','w') as f: json.dump(state, f, indent=2)

print(json.dumps({'level':level,'genesis_day':day,'expected':expected,'actual':actual,'status':'COMPLETE',
    'hypotheses':{'total':total,'passed':passed,'failed':failed,'unknown':unknown}},indent=2))
"
  ;;

# ── judge ─────────────────────────────────────────────────────────
judge)
  ws="${2:?usage: fib-harness judge <ws>}"
  py "
import json, os, glob

ws = '$ws'
with open(f'{ws}/state/harness.json') as f: state = json.load(f)
cycle = state.get('current_cycle',1)

all_h = []
level_sums = []
for lv in range(1,7):
    pat = f'{ws}/repair/cycle{cycle}/L{lv}/*.json' if cycle > 1 else f'{ws}/artifacts/L{lv}/*.json'
    lh = []
    for fp in sorted(glob.glob(pat)):
        with open(fp) as f: art = json.load(f)
        for h in art.get('hypotheses',[]):
            h['_level'] = lv; h['_file'] = os.path.basename(fp)
            lh.append(h); all_h.append(h)
    p = sum(1 for h in lh if h['status']=='pass')
    fa = sum(1 for h in lh if h['status']=='fail')
    u = sum(1 for h in lh if h['status']=='unknown')
    level_sums.append({'level':lv,'total':len(lh),'passed':p,'failed':fa,'unknown':u})

tot = len(all_h)
tp = sum(1 for h in all_h if h['status']=='pass')
tf = sum(1 for h in all_h if h['status']=='fail')
tu = sum(1 for h in all_h if h['status']=='unknown')

blocking = [{'level':h['_level'],'agent':h['_file'].replace('.json',''),'id':h['id'],
    'claim':h['claim'],'evidence':h.get('evidence',''),'repair_hint':h.get('repair_hint','')}
    for h in all_h if h['status']=='fail' and h.get('blocking',True)]

if tf == 0 and tu == 0: verdict = 'pass'
elif tf > 0: verdict = 'needs_repair'
else: verdict = 'needs_investigation'

depth = state.get('depth',1)
can_spawn = depth < state.get('max_depth', $MAX_DEPTH) and verdict != 'pass'

j = {'schema_version':'fib_judgement_v1','cycle':cycle,'timestamp':'$(now_iso)',
    'total_hypotheses':tot,'passed':tp,'failed':tf,'unknown':tu,
    'pass_rate':round(tp/tot*100,1) if tot else 0,
    'level_summaries':level_sums,'blocking_failures':blocking,'verdict':verdict,
    'can_spawn_children':can_spawn,'depth':depth,'max_depth':state.get('max_depth',$MAX_DEPTH),
    'next_action':'promote' if verdict=='pass' else ('spawn-child per failure' if can_spawn else 'verdict with reject')}

with open(f'{ws}/state/judgement-cycle{cycle}.json','w') as f: json.dump(j, f, indent=2)
state['status'] = f'judged_cycle{cycle}'; state['last_verdict'] = verdict
with open(f'{ws}/state/harness.json','w') as f: json.dump(state, f, indent=2)
print(json.dumps(j, indent=2))
"
  ;;

# ── spawn-child (FRACTAL) ────────────────────────────────────────
spawn-child)
  parent="${2:?usage: fib-harness spawn-child <parent-ws> <failure-id> <scope>}"
  fail_id="${3:?failure id}"
  scope="${4:?scope description}"
  py "
import json, os, sys, shutil

with open('$parent/state/harness.json') as f: p = json.load(f)
depth = p.get('depth',1)
if depth >= p.get('max_depth',$MAX_DEPTH):
    print(json.dumps({'error':'max depth reached','depth':depth})); sys.exit(1)

proj = p['project_path']
cd = depth + 1
cws = f'/tmp/fib-child-{os.path.basename(proj)}-d{cd}-{int(__import__(\"time\").time())}'
for lv in range(1,7): os.makedirs(f'{cws}/artifacts/L{lv}', exist_ok=True)
os.makedirs(f'{cws}/state', exist_ok=True)
os.makedirs(f'{cws}/children', exist_ok=True)

cs = {'workspace':cws,'project_path':proj,'parent_workspace':'$parent',
    'parent_failure_id':'$fail_id','scope':'$scope','depth':cd,'max_depth':p.get('max_depth',$MAX_DEPTH),
    'created':'$(now_iso)','current_level':0,'current_cycle':1,
    'dimensions_registered':False,'levels_complete':[],'children':[],'status':'initialized'}
with open(f'{cws}/state/harness.json','w') as f: json.dump(cs, f, indent=2)

scan = f'$parent/state/project-scan.json'
if os.path.exists(scan): shutil.copy2(scan, f'{cws}/state/project-scan.json')

# register in parent
cf = f'$parent/state/children.json'
children = json.load(open(cf)) if os.path.exists(cf) else []
children.append({'child_ws':cws,'failure_id':'$fail_id','scope':'$scope','depth':cd,'status':'spawned','verdict':None})
with open(cf,'w') as f: json.dump(children, f, indent=2)

p['status'] = 'awaiting_children'
if 'children' not in p: p['children'] = []
p['children'].append(cws)
with open('$parent/state/harness.json','w') as f: json.dump(p, f, indent=2)

print(json.dumps({'child_workspace':cws,'parent':'$parent','failure_id':'$fail_id','scope':'$scope',
    'depth':cd,'can_spawn_grandchildren':cd < p.get('max_depth',$MAX_DEPTH),
    'fib_sequence':[1,1,2,3,5,8]}, indent=2))
"
  ;;

# ── link-child ────────────────────────────────────────────────────
link-child)
  parent="${2:?usage: fib-harness link-child <parent-ws> <child-ws>}"
  child="${3:?child workspace}"
  py "
import json, os, sys, glob

vp = f'$child/state/verdict.json'
if not os.path.exists(vp):
    js = sorted(glob.glob(f'$child/state/judgement-cycle*.json'))
    if not js: print(json.dumps({'error':'no verdict yet'})); sys.exit(1)
    vp = js[-1]
with open(vp) as f: cv = json.load(f)

cf = f'$parent/state/children.json'
if not os.path.exists(cf): print(json.dumps({'error':'no children'})); sys.exit(1)
with open(cf) as f: children = json.load(f)

found = False
for c in children:
    if c['child_ws'] == '$child':
        c['status'] = 'resolved'
        c['verdict'] = cv.get('verdict','unknown')
        c['pass_rate'] = cv.get('pass_rate',0)
        found = True; break
if not found: print(json.dumps({'error':'child not found'})); sys.exit(1)
with open(cf,'w') as f: json.dump(children, f, indent=2)

all_done = all(c['status']=='resolved' for c in children)
all_pass = all(c.get('verdict') in ('pass','promote') for c in children)

with open(f'$parent/state/harness.json') as f: ps = json.load(f)
ps['status'] = ('children_resolved_pass' if all_pass else 'children_resolved_mixed') if all_done else 'awaiting_children'
with open(f'$parent/state/harness.json','w') as f: json.dump(ps, f, indent=2)

print(json.dumps({'linked':True,'child':'$child','child_verdict':cv.get('verdict','unknown'),
    'all_resolved':all_done,'all_pass':all_pass,
    'next_action':'verdict' if all_done else 'wait for remaining children'}, indent=2))
"
  ;;

# ── verdict ───────────────────────────────────────────────────────
verdict)
  ws="${2:?usage: fib-harness verdict <ws>}"
  py "
import json, os, glob

ws = '$ws'
with open(f'{ws}/state/harness.json') as f: state = json.load(f)

judgements = []
for jf in sorted(glob.glob(f'{ws}/state/judgement-cycle*.json')):
    with open(jf) as f: judgements.append(json.load(f))
if not judgements: print(json.dumps({'error':'no judgements'})); __import__('sys').exit(1)

last = judgements[-1]

# count agents
total_agents = 0
for cy in range(1, state.get('current_cycle',1)+1):
    base = f'{ws}/repair/cycle{cy}' if cy > 1 else f'{ws}/artifacts'
    for lv in range(1,7):
        d = f'{base}/L{lv}'
        if os.path.isdir(d): total_agents += len([f for f in os.listdir(d) if f.endswith('.json')])

# check children
cf = f'{ws}/state/children.json'
children_resolved = True
children_pass = True
if os.path.exists(cf):
    with open(cf) as f: children = json.load(f)
    children_resolved = all(c['status']=='resolved' for c in children)
    children_pass = all(c.get('verdict') in ('pass','promote') for c in children)

if last['verdict']=='pass' and children_pass: fv = 'promote'
elif not children_resolved: fv = 'hold'
elif last['verdict']=='pass' and not children_pass: fv = 'hold'
else: fv = 'reject'

v = {'schema_version':'fib_verdict_v1','timestamp':'$(now_iso)','verdict':fv,
    'cycles_run':state.get('current_cycle',1),'total_agents':total_agents,
    'hypotheses_tested':last['total_hypotheses'],'passed':last['passed'],'failed':last['failed'],
    'unknown':last['unknown'],'pass_rate':last['pass_rate'],
    'blocking_failures':last.get('blocking_failures',[]),
    'children_resolved':children_resolved,'children_pass':children_pass,
    'depth':state.get('depth',1),'workspace':ws,
    'next_action':'ship' if fv=='promote' else 'investigate' if fv=='hold' else 'fix: '+', '.join(f['claim'] for f in last.get('blocking_failures',[])[:5])}

with open(f'{ws}/state/verdict.json','w') as f: json.dump(v, f, indent=2)
state['status'] = f'verdict_{fv}'
with open(f'{ws}/state/harness.json','w') as f: json.dump(state, f, indent=2)
print(json.dumps(v, indent=2))
"
  ;;

# ── status ────────────────────────────────────────────────────────
status)
  ws="${2:?usage: fib-harness status <ws>}"
  py "
import json, os

with open('$ws/state/harness.json') as f: s = json.load(f)
fib = [1,1,2,3,5,8]
cycle = s.get('current_cycle',1)
levels = []
for lv in range(1,7):
    d = f'$ws/repair/cycle{cycle}/L{lv}' if cycle > 1 else f'$ws/artifacts/L{lv}'
    actual = len([f for f in os.listdir(d) if f.endswith('.json')]) if os.path.isdir(d) else 0
    levels.append({'level':lv,'expected':fib[lv-1],'collected':actual,'complete':actual==fib[lv-1]})

print(json.dumps({'workspace':'$ws','status':s.get('status'),'depth':s.get('depth',1),
    'cycle':cycle,'dimensions':s.get('dimensions_registered',False),
    'levels':levels,'total_expected':20,'total_collected':sum(l['collected'] for l in levels),
    'children':len(s.get('children',[]))}, indent=2))
"
  ;;

# ── tree ──────────────────────────────────────────────────────────
tree)
  ws="${2:?usage: fib-harness tree <ws>}"
  py "
import json, os, glob

def tree(ws):
    sp = f'{ws}/state/harness.json'
    if not os.path.exists(sp): return {'error': f'no state at {ws}'}
    with open(sp) as f: s = json.load(f)
    cycle = s.get('current_cycle',1)
    agents = 0
    for lv in range(1,7):
        d = f'{ws}/repair/cycle{cycle}/L{lv}' if cycle > 1 else f'{ws}/artifacts/L{lv}'
        if os.path.isdir(d): agents += len([f for f in os.listdir(d) if f.endswith('.json')])
    node = {'workspace':ws,'depth':s.get('depth',1),'status':s.get('status'),'agents':agents,
        'scope':s.get('scope','root'),'children':[]}
    vp = f'{ws}/state/verdict.json'
    if os.path.exists(vp):
        with open(vp) as f: v = json.load(f)
        node['verdict'] = v.get('verdict'); node['pass_rate'] = v.get('pass_rate',0)
    cf = f'{ws}/state/children.json'
    if os.path.exists(cf):
        with open(cf) as f: children = json.load(f)
        for c in children:
            ct = tree(c['child_ws'])
            ct['failure_id'] = c.get('failure_id')
            node['children'].append(ct)
    return node

print(json.dumps(tree('$ws'), indent=2))
"
  ;;

# ── help ──────────────────────────────────────────────────────────
help|*)
  cat <<'USAGE'
fib-harness - Fractal Fibonacci-scaled verification harness (domain-general)

COMMANDS:
  init <project-path>                        Create workspace, scan project
  dimensions <ws> <dims-json-or-@file>       Register 6 dimensions with primitive per day
  plan <ws>                                  Show primitive plan (primitives per level)
  domains                                    List known domain templates
  collect <ws> <level> <agent-id> <json>     Store one agent artifact
  level-check <ws> <level>                   Verify fib count for level
  judge <ws>                                 Level 7 break - judge all artifacts
  spawn-child <parent-ws> <fail-id> <scope>  Fractal: spawn child harness
  link-child <parent-ws> <child-ws>          Link child verdict to parent
  verdict <ws>                               Level 8 final consequence
  status <ws>                                Show current state
  tree <ws>                                  Show full fractal tree

DIMENSION SCHEMA (per entry inside dimensions[]):
  name, genesis_day (light|firmament|land|luminaries|creatures|dominion),
  question, primitive_type (code|skill|hybrid), primitive_name,
  success_criteria, and:
    code   -> commands and/or files
    skill  -> skill_invocation { skill_name, sub_task }
    hybrid -> both commands AND skill_invocation

FRACTAL FLOW:
  1..6  agents investigate (fib-scaled: 1,1,2,3,5,8 = 20 agents)
        per-level primitive can be code, skill, or hybrid (see SKILL.md)
  7     judge: pass -> verdict. fail -> spawn-child per failure domain
        each child is a FULL new 1..6 harness. children nest (max depth 3)
  8     verdict after all children resolve
USAGE
  ;;
esac
